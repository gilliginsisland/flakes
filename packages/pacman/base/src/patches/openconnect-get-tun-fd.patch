+static void pacman_debug_snapshot(struct openconnect_info *vpninfo, int timeout,
+				  int did_work, int udp_r, int tcp_r, int tun_r)
+{
+	vpninfo->pacman_debug.dtls_state = vpninfo->dtls_state;
+	vpninfo->pacman_debug.dtls_fd = vpninfo->dtls_fd;
+	vpninfo->pacman_debug.ssl_fd = vpninfo->ssl_fd;
+	vpninfo->pacman_debug.tun_fd = vpninfo->tun_fd;
+	vpninfo->pacman_debug.timeout = timeout;
+	vpninfo->pacman_debug.did_work = did_work;
+	vpninfo->pacman_debug.udp_r = udp_r;
+	vpninfo->pacman_debug.tcp_r = tcp_r;
+	vpninfo->pacman_debug.tun_r = tun_r;
+	vpninfo->pacman_debug.need_poll_cmd_fd = vpninfo->need_poll_cmd_fd;
+}
+
+static void pacman_debug_after_poll(struct openconnect_info *vpninfo, int timeout,
+				    int did_work, int udp_r, int tcp_r, int tun_r)
+{
+	pacman_debug_snapshot(vpninfo, timeout, did_work, udp_r, tcp_r, tun_r);
+	if (vpninfo->dtls_fd >= 0 && udp_r && vpninfo->dtls_state <= DTLS_DISABLED)
+		vpninfo->pacman_debug.stale_dtls_wakes++;
+}
